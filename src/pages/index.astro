---
import { getSections } from "../lib/changelogs";

const sections = await getSections();
const multi = sections.length > 1;
const heroLabel = multi ? "Changelog" : (sections[0]?.label ?? "Changelog");

const dateFormat = new Intl.DateTimeFormat("de-DE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const formatDate = (iso: string) => (iso ? dateFormat.format(new Date(iso)) : "");
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="none" />
    <title>{heroLabel} · mittwald Changelog</title>
    <style>
      :root {
        --paper: #fbfbf9;
        --card: #ffffff;
        --ink: #17171c;
        --muted: #76767f;
        --line: #ececef;
        --accent: #6b4eff;
        --accent-ink: #4a32d6;
        --accent-weak: #f0edff;
        --mono: ui-monospace, "SF Mono", "Cascadia Code", "JetBrains Mono", Menlo, monospace;
        --sans:
          system-ui, -apple-system, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      html {
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        font-family: var(--sans);
        color: var(--ink);
        background: var(--paper);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(60rem 32rem at 50% -14rem, rgba(107, 78, 255, 0.13), transparent 70%),
          var(--paper);
      }

      .wrap {
        max-width: 46rem;
        margin: 0 auto;
        padding: clamp(3rem, 8vw, 6rem) 1.25rem 6rem;
      }

      .masthead {
        margin-bottom: 2.75rem;
        animation: rise 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) both;
      }
      .kicker {
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent-ink);
        margin: 0 0 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }
      .kicker::before {
        content: "";
        width: 1.6rem;
        height: 2px;
        background: var(--accent);
        border-radius: 2px;
      }
      h1 {
        font-size: clamp(2.4rem, 7vw, 3.4rem);
        line-height: 1.02;
        letter-spacing: -0.035em;
        font-weight: 720;
        margin: 0;
      }
      .lead {
        color: var(--muted);
        font-size: 1.05rem;
        margin: 0.85rem 0 0;
        max-width: 32rem;
      }

      .tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 1.75rem;
      }
      .tab {
        appearance: none;
        font: inherit;
        font-weight: 580;
        font-size: 0.92rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.45rem 1rem;
        cursor: pointer;
        transition: all 0.18s ease;
      }
      .tab:hover {
        color: var(--ink);
        border-color: #d9d9df;
      }
      .tab[aria-selected="true"] {
        color: #fff;
        background: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 6px 18px -6px rgba(107, 78, 255, 0.6);
      }

      .timeline {
        animation: rise 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) 0.08s both;
      }

      .entry {
        position: relative;
        border-top: 1px solid var(--line);
      }
      .entry:first-child {
        border-top: 0;
      }

      summary {
        list-style: none;
        cursor: pointer;
        display: block;
        padding: 1.15rem 2.2rem 1.15rem 0;
        position: relative;
        outline: none;
      }
      summary::-webkit-details-marker {
        display: none;
      }
      summary:focus-visible {
        border-radius: 8px;
        box-shadow: 0 0 0 2px var(--accent);
      }
      .meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.3rem;
      }
      .when {
        font-family: var(--mono);
        font-size: 0.74rem;
        letter-spacing: 0.02em;
        color: var(--muted);
      }
      .badge {
        font-family: var(--mono);
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-ink);
        background: var(--accent-weak);
        padding: 0.1rem 0.45rem;
        border-radius: 999px;
      }
      .title {
        font-size: 1.18rem;
        font-weight: 640;
        letter-spacing: -0.012em;
        color: var(--ink);
        margin: 0;
        transition: color 0.15s ease;
      }
      summary:hover .title {
        color: var(--accent-ink);
      }
      .chev {
        position: absolute;
        right: 0.1rem;
        top: 1.5rem;
        width: 1.15rem;
        height: 1.15rem;
        color: #b6b6bf;
        transition:
          transform 0.25s ease,
          color 0.15s ease;
      }
      summary:hover .chev {
        color: var(--accent);
      }
      .entry[open] .chev {
        transform: rotate(180deg);
        color: var(--accent);
      }

      .body {
        padding: 0 0 1.5rem;
        max-width: 38rem;
        color: #303038;
        animation: fade 0.3s ease both;
      }
      .body > :first-child {
        margin-top: 0;
      }
      .body > :last-child {
        margin-bottom: 0;
      }
      .body p {
        margin: 0 0 0.8rem;
      }
      .body :is(ul, ol) {
        margin: 0 0 0.8rem;
        padding-left: 1.2rem;
      }
      .body li {
        margin: 0.3rem 0;
      }
      .body li::marker {
        color: var(--accent);
      }
      .body strong {
        font-weight: 660;
        color: var(--ink);
      }
      .body a {
        color: var(--accent-ink);
        text-decoration-color: rgba(107, 78, 255, 0.35);
        text-underline-offset: 2px;
      }
      .body a:hover {
        text-decoration-color: var(--accent);
      }
      .body code {
        font-family: var(--mono);
        font-size: 0.85em;
        background: #f4f4f6;
        border: 1px solid var(--line);
        border-radius: 5px;
        padding: 0.05rem 0.35rem;
      }
      .body pre {
        background: #15151b;
        color: #ededf2;
        padding: 0.9rem 1.1rem;
        border-radius: 10px;
        overflow: auto;
        font-size: 0.85rem;
      }
      .body pre code {
        background: none;
        border: 0;
        padding: 0;
        color: inherit;
      }

      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
      }
      @keyframes fade {
        from {
          opacity: 0;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
        }
        .chev,
        .tab,
        .title {
          transition: none !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg"></div>
    <main class="wrap">
      <header class="masthead">
        <p class="kicker">mittwald · Changelog</p>
        <h1>{heroLabel}</h1>
        <p class="lead">
          {
            multi
              ? "Alle Änderungen an unseren Produkten – chronologisch."
              : `Alle Neuerungen in ${heroLabel} – chronologisch.`
          }
        </p>
        {
          multi && (
            <div class="tabs" role="tablist">
              {sections.map((section, i) => (
                <button
                  class="tab"
                  type="button"
                  role="tab"
                  data-tab={section.key}
                  aria-selected={i === 0 ? "true" : "false"}
                >
                  {section.label}
                </button>
              ))}
            </div>
          )
        }
      </header>

      {
        sections.map((section, i) => (
          <section class="panel" data-panel={section.key} hidden={multi && i !== 0}>
            <div class="timeline">
              {section.entries.map((entry, idx) => (
                <details class="entry" class:list={[{ "is-new": idx === 0 }]} open={idx === 0}>
                  <summary>
                    <span class="meta">
                      <span class="when">{formatDate(entry.date)}</span>
                      {idx === 0 && <span class="badge">Neu</span>}
                    </span>
                    <span class="title">{entry.title}</span>
                    <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </summary>
                  <div class="body" set:html={entry.html} />
                </details>
              ))}
            </div>
          </section>
        ))
      }

    </main>

    {
      multi && (
        <script is:inline>
          {`
          document.querySelectorAll(".tab").forEach((tab) => {
            tab.addEventListener("click", () => {
              const key = tab.dataset.tab;
              document.querySelectorAll(".tab").forEach((t) =>
                t.setAttribute("aria-selected", String(t === tab)),
              );
              document.querySelectorAll(".panel").forEach((p) => {
                p.hidden = p.dataset.panel !== key;
              });
            });
          });
          `}
        </script>
      )
    }
  </body>
</html>
